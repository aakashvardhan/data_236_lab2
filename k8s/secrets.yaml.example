# Copy to secrets.yaml and fill in base64-encoded values. Never commit secrets.yaml.
# To encode a value: echo -n "your-value" | base64
#
# cp k8s/secrets.yaml.example k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  labels:
    app: app-secrets
type: Opaque
data:
  JWT_SECRET_KEY: <base64-encoded-secret>
  TAVILY_API_KEY: <base64-encoded-or-empty>
  GEMINI_API_KEY: <base64-encoded-or-empty>
  HF_API_TOKEN: <base64-encoded-or-empty>
