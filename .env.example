# Copy to .env and fill in real values. Never commit .env.
# cp .env.example .env

# -----------------------------------------------------------------------------
# Legacy Lab 1 backend (backend/app) — MySQL + SQLAlchemy
# Local dev: DB_HOST=localhost. Docker stack: DB_HOST=mysql (if MySQL is a service).
# -----------------------------------------------------------------------------
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yelp_db

JWT_SECRET_KEY=replace-with-a-long-random-string
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

TAVILY_API_KEY=
GEMINI_API_KEY=
HF_API_TOKEN=
YELP_API_KEY=

# -----------------------------------------------------------------------------
# Microservices (services/*) — MongoDB + Kafka
# docker-compose sets these; for local runs use mongodb://localhost:27017
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=yelp_db
KAFKA_BROKER=localhost:9092

# -----------------------------------------------------------------------------
# Workers (services/workers/*)
# -----------------------------------------------------------------------------
# KAFKA_BROKER and MONGO_* same as above when running workers locally

# -----------------------------------------------------------------------------
# MySQL → MongoDB migration (scripts/migrate_mysql_to_mongo.py)
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=yelp_db
# MONGO_URI / MONGO_DB_NAME — reuse microservice vars above

# -----------------------------------------------------------------------------
# Utilities
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (Vite) — optional; see frontend/src/utils/url.js
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=http://localhost:8000
